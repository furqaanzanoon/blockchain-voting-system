# ============================================================
#  BLOCKCHAIN VOTING SYSTEM — API Environment Secrets
#  Copy this file to .env (or use dotnet user-secrets / Azure Key Vault)
#  NEVER commit real values to source control.
# ============================================================

# SQL Server connection string
DbConnection="Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True"

# JWT configuration
Jwt__Key="your-super-secret-jwt-key-minimum-32-chars"
Jwt__Issuer="VotingAPI"
Jwt__Audience="voting-web"
Jwt__ExpireDays=1

# SMTP email settings
EmailSettings__Host="smtp.gmail.com"
EmailSettings__Port=587
EmailSettings__Email="your-email@gmail.com"
EmailSettings__Password="your-app-password"

# Blockchain / Ethereum settings
BlockchainSettings__NodeUrl="https://ethereum-sepolia-rpc.publicnode.com"
BlockchainSettings__AdminPrivateKey="0xYOUR_PRIVATE_KEY_HERE"
BlockchainSettings__AccessControlAddress="0x..."
BlockchainSettings__ZKVerifierAddress="0x..."
BlockchainSettings__VoterRegistryAddress="0x..."
BlockchainSettings__BallotFactoryAddress="0x..."
BlockchainSettings__ResultAggregatorAddress="0x..."
